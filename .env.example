# Supabase (server-side only — no NEXT_PUBLIC_ vars needed; single-user tool)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Shared secret checked by /api/watch/run (Authorization: Bearer <CRON_SECRET>).
# Set in Vercel env AND as a GitHub Actions secret for the external scheduler.
CRON_SECRET=<random-long-string>

# Contact URL/email advertised in the Showdown User-Agent (politeness requirement)
SHOWDOWN_CONTACT=you@example.com
